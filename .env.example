# 必填 redis 和 mongoDB
# Docker Compose 默认使用服务名
REDIS_HOST=bulita-redis
REDIS_PORT=6380
REDIS_PASSWORD=bulita123456
MONGODB_HOST=bulita-mongodb
MONGODB_PORT=27018
MONGODB_USERNAME=bulita
MONGODB_PASSWORD=bulita123456
MONGODB_DATABASE=bulita
MONGODB_AUTH_SOURCE=admin

# 你应该自己修改的配置
# JWT密钥, 为了安全,你必须修改下面的字符串
JWT_SECRET=ysehh4qM3ZuNzJHArC2XvB99jfOV6lMY
# 默认群组名字
DEFAULT_GROUP_NAME=AI聊天室
# 默认网站title名字
DEFAULT_TITLE='AI聊天室'
# Google 登录客户端 ID
# 控制台: https://console.cloud.google.com/auth/clients
# 官方说明: https://support.google.com/cloud/answer/15549257?hl=en
# GIS 文档: https://developers.google.com/identity/gsi/web/guides/get-google-api-clientid
# 如遇 error 400: origin_mismatch，请到 OAuth Client 的 Authorized JavaScript origins 中添加当前前端访问源
# 只能填写协议+域名(+端口)，不能带路径，例如: https://bulita.net 或 http://localhost:8080
GOOGLE_CLIENT_ID=972530630757-f48rgnqtdabc7vv9vhflh66ah7ba76js.apps.googleusercontent.com
# 必填：默认管理员邮箱，多个用逗号分隔；首个邮箱会作为默认群创建者的预创建账号
ADMIN_EMAILS=yourname@gmail.com
# 机器人列表, 多个用逗号隔开
BOTS=AI
# 群聊 AI 开关：true 开启，false 关闭。也可在管理员控制台随时切换
GROUP_AI_SWITCH=false
# 默认 AI 服务配置（OpenAI / NewAPI 兼容）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_CONTEXT_COUNT=10
# 允许用户创建的最大群组数量, 管理员不受限制
MAX_GROUP_NUM=0
# 是否只允许搜索默认群组
ONLY_SEARCH_DEFAULT_GROUP=true
# 私聊消息通知回调域名
PRIVATE_MSG_CALLBACK_DOMAIN=https://chat.bulita.net

# 这些配置你可以不用修改
# JWT Token有效期, 单位:秒
TOKEN_EXPIRES_TIME=2592000
# 默认提示音
#[apple pcqq mobileqq huaji]
SOUND='apple'
# 获取IP定位接口 GET 接口自动与IP进行拼接, http://xxx/ip/
IP_LOCATION_API=
# 用户每分钟发言最大次数
MAX_CALL_PER_MINUTES=8
# 禁言后自动解除的持续时间, 单位:秒
LIFT_BAN_DURATION=10
# 封禁用户持续时间, 单位:秒
SEAL_USER_DURATION=86400
